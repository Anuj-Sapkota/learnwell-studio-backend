generator client {
  provider = "prisma-client-js"
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String          @id @default(uuid())
  email         String          @unique
  password_hash String?
  fullName      String
  phoneNumber   String?         @unique
  role          Role            @default(STUDENT)
  isVerified    Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  courses       Course[]
  sessions      DeviceSession[]
  enrollments   Enrollment[]
  submissions   Submission[]
  lessonProgress LessonProgress[]
  profile       Profile?
}

model Profile {
  id     String  @id @default(uuid())
  bio    String?
  avatar String?
  userId String  @unique
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DeviceSession {
  id         String   @id @default(uuid())
  token      String   @unique
  ipAddress  String   @db.VarChar(45)
  userAgent  String
  deviceType String?
  lastActive DateTime @default(now())
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Course {
  id              String       @id @default(uuid())
  title           String
  shortDescription String     
  description     String?
  thumbnail       String?
  price           Float        @default(0)
  discount        Float        @default(0)
  discountExpiresAt DateTime?                   // null = discount never expires
  isFree          Boolean      @default(false)
  accessDuration  Int?
  categoryId      String?
  level           String       @default("BEGINNER")
  totalDuration   Int          @default(0)
  instructorId    String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  enrollmentCount Int          @default(0)
  lectureCount    Int          @default(0)
  notesCount      Int          @default(0)
  subjectCount    Int          @default(1)
  videoCount      Int          @default(0)
  prerequisites   String[]     @default([])
  instructor      User         @relation(fields: [instructorId], references: [id])
  category        Category?    @relation(fields: [categoryId], references: [id])
  enrollments     Enrollment[]
  sections        Section[]
  assignments     Assignment[]
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  courses     Course[]
}

model Section {
  id       String   @id @default(uuid())
  title    String
  order    Int      @default(0)
  courseId String
  lessons  Lesson[]
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Lesson {
  id           String      @id @default(uuid())
  title        String
  contentType  ContentType @default(TEXT)
  content      String?
  videoUrl     String?
  videoName    String?
  pdfUrl       String?
  documentName String?
  duration     Int         @default(0)
  order        Int         @default(0)
  sectionId    String
  section      Section     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  progress     LessonProgress[]
}

model LessonProgress {
  id             String    @id @default(uuid())
  userId         String
  lessonId       String
  watchedPercent Float     @default(0)   // 0-100
  isUnlocked     Boolean   @default(false)
  completedAt    DateTime?
  updatedAt      DateTime  @updatedAt

  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson  Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

enum ContentType {
  VIDEO
  PDF
  TEXT
  MIXED  // video or pdf + rich text together
}

model Enrollment {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())

  course    Course   @relation(fields: [courseId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
}

model Assignment {
  id          String         @id @default(uuid())
  title       String
  description String?
  type        AssignmentType @default(FILE_SUBMISSION)
  files       Json           @default("[]")  // [{ name, url, type }] for FILE_SUBMISSION
  questions   Json           @default("[]")  // [{ question, options: [], correctIndex }] for MCQ
  dueDate     DateTime?
  courseId    String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  submissions Submission[]
}

enum AssignmentType {
  FILE_SUBMISSION
  MCQ
}

model Submission {
  id           String    @id @default(uuid())
  fileUrl      String?
  fileName     String?
  textContent  String?
  mcqAnswers   Json?     // [{ questionIndex, selectedIndex }] for MCQ submissions
  mcqScore     Float?    // auto-calculated for MCQ
  submittedAt  DateTime  @default(now())
  grade        Float?
  maxGrade     Float     @default(100)
  feedback     String?
  gradedAt     DateTime?
  userId       String
  assignmentId String

  user         User       @relation(fields: [userId], references: [id])
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([userId, assignmentId])
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}
