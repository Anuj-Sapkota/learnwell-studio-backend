generator client {
  provider = "prisma-client-js"
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String          @id @default(uuid())
  email         String          @unique
  password_hash String?
  fullName      String
  phoneNumber   String?         @unique
  role          Role            @default(STUDENT)
  isVerified    Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  courses       Course[]
  sessions      DeviceSession[]
  enrollments   Enrollment[]
  profile       Profile?
}

model Profile {
  id     String  @id @default(uuid())
  bio    String?
  avatar String?
  userId String  @unique
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DeviceSession {
  id         String   @id @default(uuid())
  token      String   @unique
  ipAddress  String   @db.VarChar(45)
  userAgent  String
  deviceType String?
  lastActive DateTime @default(now())
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Course {
  id              String       @id @default(uuid())
  title           String
  shortDescription String     
  description     String?
  thumbnail       String?
  price           Float        @default(0)
  discount        Float        @default(0)   // percentage discount e.g. 20 = 20%
  isFree          Boolean      @default(false)
  accessDuration  Int?                        // days; null = lifetime access
  category        String?
  level           String       @default("BEGINNER")
  totalDuration   Int          @default(0)
  instructorId    String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  enrollmentCount Int          @default(0)
  lectureCount    Int          @default(0)
  notesCount      Int          @default(0)
  subjectCount    Int          @default(1)
  videoCount      Int          @default(0)
  prerequisites   String[]     @default([])
  instructor      User         @relation(fields: [instructorId], references: [id])
  enrollments     Enrollment[]
  sections        Section[]
}

model Section {
  id       String   @id @default(uuid())
  title    String
  order    Int      @default(0)
  courseId String
  lessons  Lesson[]
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Lesson {
  id           String  @id @default(uuid())
  title        String
  content      String?
  videoUrl     String?
  videoName    String?  // original filename of the uploaded video
  pdfUrl       String?
  documentName String?  // original filename of the uploaded document
  duration     Int     @default(0)
  order        Int     @default(0)
  sectionId    String
  section      Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())

  course    Course   @relation(fields: [courseId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}
