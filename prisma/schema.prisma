// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// User Model for Authentication & Profile
model User {
  id            String   @id @default(uuid()) // Using UUID for better security
  email         String   @unique
  password_hash String // Will store Hashed passwords
  fullName      String
  phoneNumber   String?  @unique
  role          Role     @default(STUDENT) // Role-based access control
  isVerified    Boolean  @default(false) // For email/OTP verification
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Profile relation
  profile  Profile?
  sessions DeviceSession[]
}

// Separate Profile model for bio, avatars, etc.
model Profile {
  id     String  @id @default(uuid())
  bio    String?
  avatar String?
  userId String  @unique
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DeviceSession {
  id         String  @id @default(uuid())
  token      String  @unique
  // Information about the connection
  ipAddress  String  @db.VarChar(45) // Supports IPv4 and IPv6
  userAgent  String  @db.Text // Stores browser/OS details
  deviceType String? // e.g., "Mobile", "Desktop", "Tablet"

  // Timing
  lastActive DateTime @default(now())
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now())

  // Relationship to User
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId]) // Improves speed 
}

// Enum for Roles
enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}
